{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HiCodex",
  "version": "0.1.0",
  "identifier": "com.hicodex.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5178",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HiCodex",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data: blob: file:; style-src 'self' 'unsafe-inline';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [],
    "resources": {
      "binaries": "binaries"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
