{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge",
  "mainBinaryName": "Forge",
  "version": "0.1.0",
  "identifier": "com.forge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5178",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Forge",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true,
        "center": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$TEMP/**", "/tmp/**", "/private/tmp/**", "/Volumes/**"]
      },
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://127.0.0.1:5050 http://localhost:5050; img-src 'self' data: blob: file: asset: http://asset.localhost https: http:; style-src 'self' 'unsafe-inline';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries": "binaries"
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["codex"],
        "name": "com.forge.desktop.deeplink",
        "role": "Viewer"
      }
    },
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
