{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HiCodex",
  "version": "0.1.0",
  "identifier": "com.hicodex.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5178",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HiCodex",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "dragDropEnabled": false,
        "center": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$TEMP/**", "/tmp/**", "/private/tmp/**", "/Volumes/**"]
      },
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data: blob: file: asset: http://asset.localhost https: http:; style-src 'self' 'unsafe-inline';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [],
    "resources": {
      "binaries": "binaries"
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://placeholder.invalid/hicodex/{{target}}/{{arch}}/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNUQzNjk0RTBDNjY1QkYKUldTL1pjYmdsRFpkZ1dZYm8ycEE5VE5NdkR0Q3ZvSzRsNmhKOXVaN3FkQlcvQXpMN1RMaThDY24K"
    }
  }
}
