{
  "name": "@forge/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/ensure-dev-server.mjs",
    "dev:server": "vite --host 127.0.0.1 --port 5178",
    "build": "tsc --noEmit --pretty false && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4178",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "node --test scripts/tauri-release-config.test.mjs",
    "release:config": "node scripts/tauri-release-config.mjs --check",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build": "tauri build",
    "tauri:build:release": "node scripts/tauri-release-config.mjs --build"
  },
  "dependencies": {
    "@forge/codex-protocol": "0.1.0",
    "@forge/ui": "0.1.0",
    "@tauri-apps/api": "^2.11.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
