{
  "name": "@forge/internal-api-mcp-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Demo MCP server exposing an internal API to Forge / Codex Desktop.",
  "main": "dist/server.js",
  "bin": {
    "forge-internal-api-mcp": "dist/server.js"
  },
  "scripts": {
